# Copy lombok configurations from new_application
config.stopBubbling = true

# Generate @ConstructorProperties for Spring/Jackson compatibility
lombok.anyConstructor.addConstructorProperties = true

# Use standard logger names
lombok.log.fieldName = log

# Enable fluent chaining on accessors
lombok.accessors.chain = true
lombok.accessors.fluent = false

# Warn against using @Data
lombok.data.flagUsage = warning
lombok.value.flagUsage = warning

# Default field access level
lombok.fieldDefaults.defaultPrivate = true
lombok.fieldDefaults.defaultFinal = false

# Constructor behavior
lombok.anyConstructor.suppressConstructorProperties = true
